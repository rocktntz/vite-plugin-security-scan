{
  "name": "vite-plugin-security-scan",
  "version": "1.0.1",
  "description": "Vite plugin for scanning security risks in frontend code",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "node test/test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "plugin",
    "security",
    "xss",
    "scan",
    "ast",
    "frontend-security",
    "code-analysis",
    "vue"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rocktntz/vite-plugin-security-scan.git"
  },
  "homepage": "https://github.com/rocktntz/vite-plugin-security-scan#readme",
  "bugs": {
    "url": "https://github.com/rocktntz/vite-plugin-security-scan/issues"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/picomatch": "^4.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "picomatch": "^4.0.4"
  }
}
